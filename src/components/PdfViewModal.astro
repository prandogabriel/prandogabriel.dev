---
// src/components/PdfViewModal.astro
export interface Props {
  title: string;
  pdfUrl: string;
  fileName: string;
  modalId?: string;
}

const { title, pdfUrl, fileName, modalId = 'pdf-modal' } = Astro.props;
const isLocalFile = pdfUrl.startsWith('/');
const viewerUrl = isLocalFile
  ? pdfUrl
  : `https://docs.google.com/viewer?url=${encodeURIComponent(pdfUrl)}&embedded=true`;
---

<dialog
  id={modalId}
  data-pdf-modal
  aria-labelledby={`${modalId}-title`}
  class="pdf-modal m-0 h-full max-h-none w-full max-w-none overflow-visible border-0 bg-transparent p-4 backdrop:bg-black/65"
>
  <div class="mx-auto flex max-h-[90vh] w-full max-w-4xl flex-col overflow-hidden rounded-[1.75rem] border border-default bg-[var(--color-paper)] shadow-[var(--shadow-sheet)]">
    <div class="flex items-center justify-between border-b border-default p-4">
      <h2 id={`${modalId}-title`} class="font-display text-xl font-semibold text-default">{title}</h2>
      <button data-pdf-modal-close type="button" class="text-offset transition-colors hover:text-default" aria-label="Close modal">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div class="flex-grow overflow-y-auto p-1">
      <iframe
        src={viewerUrl}
        title={title}
        class="h-[calc(90vh-100px)] w-full border-0"
        data-onerror="this.onerror=null; this.src='about:blank'; this.parentElement.innerHTML='<div class=\'flex h-full items-center justify-center\'><p class=\'text-red-500\'>Failed to load PDF. Please try downloading instead.</p></div>';"
      ></iframe>
    </div>
    <div class="flex justify-end border-t border-default p-4">
      <a
        href={pdfUrl}
        download={fileName}
        class="button-primary"
      >
        Download PDF
      </a>
    </div>
  </div>
</dialog>

<script is:inline>
  const modalWindow = window;

  if (!modalWindow['__pdfModalInit']) {
    modalWindow['__pdfModalInit'] = true;

    const openDialogs = () =>
      Array.from(document.querySelectorAll('dialog[data-pdf-modal][open]')).filter(
        (node) => node instanceof HTMLDialogElement
      );

    const syncBodyScroll = () => {
      document.body.style.overflow = openDialogs().length > 0 ? 'hidden' : '';
    };

    const openModal = (dialog) => {
      openDialogs().forEach((node) => {
        if (node !== dialog) node.close();
      });
      if (!dialog.open) dialog.showModal();
      syncBodyScroll();
    };

    const closeModal = (dialog) => {
      if (dialog.open) dialog.close();
      syncBodyScroll();
    };

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const openTrigger = target.closest('[data-pdf-modal-open]');
      if (openTrigger) {
        const targetId = openTrigger.getAttribute('data-pdf-modal-open');
        if (!targetId) return;
        const dialog = document.getElementById(targetId);
        if (dialog instanceof HTMLDialogElement) {
          event.preventDefault();
          openModal(dialog);
        }
        return;
      }

      const closeTrigger = target.closest('[data-pdf-modal-close]');
      if (closeTrigger) {
        const dialog = closeTrigger.closest('dialog');
        if (dialog instanceof HTMLDialogElement) {
          event.preventDefault();
          closeModal(dialog);
        }
        return;
      }

      if (target instanceof HTMLDialogElement && target.matches('[data-pdf-modal]')) {
        closeModal(target);
      }
    });

    document.querySelectorAll('dialog[data-pdf-modal]').forEach((node) => {
      if (!(node instanceof HTMLDialogElement)) return;

      node.addEventListener('cancel', (event) => {
        event.preventDefault();
        closeModal(node);
      });

      node.addEventListener('close', () => {
        syncBodyScroll();
      });
    });
  }
</script>
