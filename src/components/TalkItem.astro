---
import PdfViewModal from './PdfViewModal.astro';
import { Icon } from 'astro-icon/components';

const { title, event, date, link, language = 'pt-br' } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
});

const fileName = link.split('/').pop() || 'talk.pdf';
const modalId = `talk-modal-${fileName.replace(/[^a-z0-9]/gi, '-').toLowerCase()}`;
---

<article class="grid gap-5 px-6 py-6 md:grid-cols-[6.5rem_minmax(0,1fr)_auto] md:items-start md:px-8">
  <div class="md:pt-1">
    <p class="eyebrow">{formattedDate}</p>
  </div>

  <div class="min-w-0">
    <div class="flex flex-wrap items-center gap-2">
      <p class="text-sm text-offset">{event}</p>
      <span class="text-[0.7rem] uppercase tracking-[0.16em] text-offset/70">/</span>
      <span class="resume-chip">{language}</span>
    </div>
    <h2 class="mt-3 max-w-3xl font-display text-xl font-semibold leading-8 tracking-[-0.03em] text-default md:text-2xl">
      {title}
    </h2>
  </div>

  <div class="flex md:justify-end">
    <button
      class="button-secondary inline-flex items-center gap-2"
      data-pdf-modal-open={modalId}
      type="button"
    >
      Open deck
      <Icon class="h-4 w-4" name="ArrowRight" />
    </button>
  </div>
</article>

<PdfViewModal
  title={title}
  pdfUrl={link}
  fileName={fileName}
  modalId={modalId}
/>
