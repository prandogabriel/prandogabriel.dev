---
import { talks } from '../config/cv.json';
import TalkItem from './TalkItem.astro';
---

<section class="py-12 bg-background">
  <div class="mx-auto max-w-5xl px-4 py-4 sm:px-6 lg:px-8">
    <div class="space-y-8">
      <div class="rounded-[1.75rem] border border-default bg-[var(--color-paper)] px-6 py-7 shadow-[var(--shadow-soft)] sm:px-8">
        <p class="eyebrow">Talks</p>
        <h1 class="mt-3 font-display text-4xl font-semibold tracking-[-0.04em] text-default">
          Public speaking
        </h1>
      </div>

      <div class="min-w-0 rounded-[1.75rem] border border-default bg-[var(--color-paper)] shadow-[var(--shadow-soft)] divide-y divide-default">
        {talks.map((talk) => (
          <TalkItem
            link={talk.link}
            title={talk.title}
            event={talk.event}
            date={talk.date}
          />
        ))}
      </div>
    </div>
  </div>
</section>
