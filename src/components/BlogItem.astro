---
import type { CollectionEntry } from 'astro:content';
import { Icon } from 'astro-icon/components';

interface Props {
  blog: CollectionEntry<'blogs'>;
}

const { blog } = Astro.props;

const formattedDate = new Date(blog.data.datetime).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<li>
  <a
    href={`/blogs/${blog.id}`}
    class="group grid gap-5 py-8 transition-colors duration-200 md:grid-cols-[6.5rem_minmax(0,1fr)_10rem] md:items-start"
  >
    <div class="md:pt-1">
      <p class="eyebrow">{formattedDate}</p>
    </div>

    <div>
      <h3 class="font-display text-2xl font-semibold tracking-[-0.04em] text-default transition-colors group-hover:text-primary">
        {blog.data.title}
      </h3>
      <p class="mt-3 max-w-2xl text-sm leading-7 text-offset">
        {blog.data.description}
      </p>
      <span class="mt-5 inline-flex items-center gap-2 text-sm font-medium text-primary">
        Read article
        <Icon class="h-4 w-4 transition-transform group-hover:translate-x-1" name="ArrowRight" />
      </span>
    </div>

    {blog.data.image && (
      <div class="overflow-hidden rounded-[1.25rem] border border-default bg-default md:mt-1">
        <img
          src={blog.data.image}
          alt={blog.data.title}
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
        />
      </div>
    )}
  </a>
</li>
