---
import { Icon } from 'astro-icon/components';

interface Props {
  icon: string;
  title: string;
  content: string;
  href?: string;
  isLink?: boolean;
}

const { icon, title, content, href, isLink = false } = Astro.props;
const displayHref = href
  ? href.startsWith('mailto:')
    ? href.replace('mailto:', '')
    : (() => {
        try {
          return new URL(href).hostname.replace(/^www\./, '');
        } catch {
          return href;
        }
      })()
  : null;
--- 

<div class="overflow-hidden rounded-[1.5rem] border border-default bg-background-offset p-5 shadow-[var(--shadow-soft)]">
  <div class="flex items-start gap-4">
    <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border border-default bg-default">
      <Icon name={icon} class="h-5 w-5 text-primary" />
    </div>
    <div class="min-w-0">
      <p class="eyebrow mb-2">{title}</p>
      {isLink && href ? (
        <a
          href={href}
          target={href.startsWith('mailto:') ? undefined : '_blank'}
          rel={href.startsWith('mailto:') ? undefined : 'noopener noreferrer'}
          class="story-link block break-words text-sm leading-6 text-default"
        >
          {content}
        </a>
      ) : (
        <p class="break-words text-sm leading-6 text-default">{content}</p>
      )}
      {displayHref && displayHref !== content && (
        <p class="mt-2 break-all text-xs leading-5 text-offset">
          {displayHref}
        </p>
      )}
    </div>
  </div>
</div>
