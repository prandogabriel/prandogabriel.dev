---
import { basic } from '../../config/cv.json';
const currentYear = new Date().getFullYear();
---

<footer class="relative z-10 px-4 pb-10 pt-4 sm:px-6 lg:px-8">
  <div class="mx-auto flex max-w-7xl flex-col gap-4 rounded-[2rem] border border-default bg-background-offset px-6 py-6 shadow-[var(--shadow-soft)] backdrop-blur md:flex-row md:items-center md:justify-between">
    <div>
      <p class="font-display text-lg font-semibold tracking-[-0.04em] text-default">
        {basic?.name}
      </p>
      <p class="mt-1 text-sm text-offset">
        © {currentYear} All rights reserved.
      </p>
    </div>

    <div class="flex flex-wrap items-center gap-5 text-sm text-offset">
      <a class="transition-colors hover:text-default" href="/talks">Talks</a>
      <a class="transition-colors hover:text-default" href="/blogs">Blog</a>
      <a class="transition-colors hover:text-default" href="/contact">Contact</a>
      <a class="transition-colors hover:text-default" href={basic?.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a class="transition-colors hover:text-default" href={basic?.github} target="_blank" rel="noopener noreferrer">GitHub</a>
    </div>
  </div>
</footer>
