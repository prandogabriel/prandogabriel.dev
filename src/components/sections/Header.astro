---
import ThemeToggle from '../ThemeToggle.astro';
import { basic } from '../../config/cv.json';

const menuItems = [
  { name: 'About', href: '/' },
  { name: 'Talks', href: '/talks' },
  { name: 'Blog', href: '/blogs' },
  { name: 'Contact', href: '/contact' },
];
---

<header class="relative z-20 px-4 pt-4 sm:px-6 lg:px-8 lg:pt-6">
  <div class="mx-auto max-w-7xl border-b border-default pb-4">
    <div class="flex items-end justify-between gap-6">
      <div>
        <a href="/" class="font-display text-2xl font-semibold tracking-[-0.04em] text-default transition-colors hover:text-primary">
          {basic?.name}
        </a>
        <p class="mt-1 text-sm text-offset">Senior software engineer</p>
      </div>

      <div class="flex items-center gap-3">
        <nav class="hidden items-center gap-6 md:flex">
        {menuItems.map((item) => (
            <a href={item.href} class="text-sm text-offset transition-colors hover:text-default">{item.name}</a>
        ))}
        </nav>

        <div class="flex items-center gap-2 md:hidden">
          <button id="menu-btn" class="inline-flex items-center justify-center border-b border-default pb-1 text-sm text-default">
            Menu
          </button>
        </div>

        <ThemeToggle />
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="mx-auto mt-3 hidden max-w-7xl border-b border-default px-1 pb-4 md:hidden">
    <nav class="flex flex-col gap-3">
      {menuItems.map((item) => (
        <a href={item.href} class="text-sm text-offset transition-colors hover:text-default">
          {item.name}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
