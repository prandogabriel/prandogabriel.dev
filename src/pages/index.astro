---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import ResumeSheet from '../components/home/ResumeSheet.astro';
import SelectedWriting from '../components/home/SelectedWriting.astro';

const blogs = await getCollection('blogs', ({ data }) => !data.draft);
const featuredPosts = blogs
  .sort((a, b) => new Date(b.data.datetime).getTime() - new Date(a.data.datetime).getTime())
  .slice(0, 2);
---

<Layout title="Gabriel Prando" showHeader={false}>
  <ResumeSheet />
  <SelectedWriting posts={featuredPosts} />
</Layout>
